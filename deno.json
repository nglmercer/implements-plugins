{
  "name": "@deno/plugin-system",
  "version": "0.1.0",
  "exports": "./mod.ts",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/path": "jsr:@std/path@^1.0.0"
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.ns", "deno.window"]
  },
  "tasks": {
    "test": "deno test --allow-read --allow-env",
    "test:coverage": "deno test --allow-read --allow-env --coverage",
    "server": "deno run --allow-net --allow-read --allow-env examples/web-server.ts",
    "client": "deno run --allow-net examples/fetch-plugin.ts"
  }
}
