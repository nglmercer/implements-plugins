{
  "name": "@deno/plugin-system",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.ts",
    "test:deno": "deno test --allow-read --allow-env --allow-import --allow-net tests/**/*.test.ts",
    "test:bun": "bun test tests/**/*.test.ts",
    "build": "tsup",
    "build:watch": "tsup --watch"
  },
  "keywords": [
    "plugin",
    "loader",
    "deno",
    "bun",
    "node",
    "universal"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.1.0",
    "typescript": "^5.7.3",
    "@types/node": "^20"
  },
  "dependencies": {}
}
