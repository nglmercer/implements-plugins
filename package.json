{
  "name": "@deno/plugin-system",
  "version": "0.1.0",
  "type": "module",
  "main": "./mod.ts",
  "types": "./mod.ts",
  "exports": {
    ".": "./mod.ts"
  },
  "files": [
    "mod.ts",
    "src/**/*.ts",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.ts",
    "test:deno": "deno test --allow-read --allow-env --allow-import --allow-net tests/**/*.test.ts",
    "test:bun": "bun test tests/**/*.test.ts",
    "build:js": "bun build ./mod.ts --outdir ./dist --target node",
    "build:types": "tsc",
    "build": "bun run build:js && bun run build:types"
  },
  "keywords": [
    "plugin",
    "loader",
    "deno",
    "bun",
    "node",
    "universal"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
